# 复制为 .env 后填写（不要提交 .env 到 Git）

# ============ 必填 ============

# JWT 鉴权密钥，至少 32 位随机字符串
# 生成示例：openssl rand -base64 48
AUTH_SECRET=请替换为至少32位随机密钥

# CORS 允许的来源域名（生产环境必须设置，开发环境可使用 *）
# CORS_ORIGIN=https://your-frontend-domain.com

# Redis 密码（用于docker-compose中Redis认证）
# REDIS_PASSWORD=xiangtai_redis_dev

# ============ 快递100物流查询（可选）============

KUAIDI100_CUSTOMER=
KUAIDI100_KEY=
# KUAIDI100_QUERY_URL=https://poll.kuaidi100.com/poll/query.do
# KUAIDI100_WEB_QUERY_URL=https://www.kuaidi100.com/query

# ============ 汇率服务（可选）============

# EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/CNY

# ============ 飞书通知（可选）============

# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ============ 数据库（PostgreSQL）============

# 开发推荐用 docker compose 起的 Postgres
# ⚠️ 宿主机端口用 5433（避开本机可能已有的 Postgres 5432）
# 本机直连 Docker 容器：postgresql://xiangtai:xiangtai_dev@localhost:5433/xiangtai?schema=public
# 容器内 API 访问（docker compose 内部网络，容器内仍是 5432）：postgresql://xiangtai:xiangtai_dev@postgres:5432/xiangtai?schema=public
# 生产环境（如 Render Postgres / AWS RDS）：填运营方提供的连接串
DATABASE_URL=postgresql://xiangtai:xiangtai_dev@localhost:5433/xiangtai?schema=public

# Postgres 容器初始化参数（仅 docker compose 用，本机直连无需关心）
POSTGRES_USER=xiangtai
POSTGRES_PASSWORD=xiangtai_dev
POSTGRES_DB=xiangtai

# ============ 异步任务队列（Redis）============

# 本机直连 Docker：redis://:xiangtai_redis_dev@localhost:6379
# 容器内 API 访问：redis://:xiangtai_redis_dev@redis:6379
REDIS_URL=redis://:xiangtai_redis_dev@localhost:6379

# ============ 前端访问后端的地址 ============

# 浏览器访问后端的完整根地址（含协议与端口，无尾部斜杠）
# 本机 Docker：http://你的服务器公网IP:3001
# 已绑定域名与 HTTPS：https://api.你的域名.com
# 同一局域网他人访问本机开发服务：填本机局域网 IP，例如 http://192.168.1.100:3001（勿用 127.0.0.1）
# 或根目录执行 npm run dev:web:lan 自动写入本机 IP
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001

# ============ DeepSeek AI（可选；不填则相关接口不可用）============

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/chat/completions
