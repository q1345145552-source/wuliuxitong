{
  "name": "xiangtai-logistics",
  "private": true,
  "description": "湘泰物流：根目录安装 tsx 后可在仓库根运行后端；前端在 apps/web",
  "scripts": {
    "postinstall": "npm install --prefix apps/web",
    "build": "npm run build --prefix apps/web",
    "start": "npm run start --prefix apps/web",
    "dev:api": "tsx apps/api/src/main.ts",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:web:public": "npm run dev:public --prefix apps/web",
    "dev:web:lan": "node scripts/dev-web-lan.mjs",
    "build:web": "npm run build --prefix apps/web",
    "start:web": "npm run start --prefix apps/web",
    "db:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=apps/api/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=apps/api/prisma/schema.prisma",
    "db:seed": "tsx apps/api/prisma/seed.ts",
    "db:reset": "prisma migrate reset --schema=apps/api/prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "ssh2": "^1.17.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
