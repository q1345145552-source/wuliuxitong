# 湘泰物流网站 — 环境变量

# API 地址（必填）：用户在浏览器访问的 API 地址
# 本地开发: http://localhost:3001
# 服务器部署: https://api.xianlianth.com
NEXT_PUBLIC_API_BASE_URL=https://api.xianlianth.com

# JWT 签名密钥（必填）
AUTH_SECRET=your-secret-here

# 数据库（可选）
POSTGRES_USER=xiangtai
POSTGRES_PASSWORD=xiangtai_dev
POSTGRES_DB=xiangtai

# Redis（可选）
REDIS_PASSWORD=xiangtai_redis_dev

# AI（可选）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/chat/completions
