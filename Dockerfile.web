# 前端：Next.js 生产构建（构建时注入浏览器可访问的 API 根地址）
FROM node:22-alpine AS builder

WORKDIR /app

COPY packages/shared-types ./packages/shared-types
COPY apps/web/package.json apps/web/package-lock.json ./apps/web/

WORKDIR /app/apps/web

RUN npm ci

COPY apps/web .

ARG NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}

RUN npm run build

FROM node:22-alpine AS runner

WORKDIR /app/apps/web

ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

COPY --chown=node:node --from=builder /app/apps/web/.next ./.next
COPY --chown=node:node --from=builder /app/apps/web/public ./public
COPY --chown=node:node --from=builder /app/apps/web/package.json ./
COPY --chown=node:node --from=builder /app/apps/web/package-lock.json ./
COPY --chown=node:node --from=builder /app/apps/web/next.config.ts ./
COPY --chown=node:node --from=builder /app/apps/web/tsconfig.json ./
COPY --chown=node:node --from=builder /app/apps/web/node_modules ./node_modules

EXPOSE 3000

USER node

CMD ["npm", "run", "start"]
